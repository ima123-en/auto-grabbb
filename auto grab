local function getHRP()
    local c = LocalPlayer.Character
    return c and c:FindFirstChild("HumanoidRootPart")
end

local function isMyPlot(plot)
    for _, o in pairs(plot:GetDescendants()) do
        if o:IsA("TextLabel") and o.Text and (o.Text:find(LocalPlayer.Name) or o.Text:find(LocalPlayer.DisplayName)) then
            return true
        end
    end
    return false
end

local function findPromptInPodium(podium)
    for _, d in pairs(podium:GetDescendants()) do
        if d:IsA("ProximityPrompt") and d.Enabled then
            local pos
            if d.Parent:IsA("Attachment") and d.Parent.Parent:IsA("BasePart") then
                pos = d.Parent.Parent.Position
            elseif d.Parent:IsA("BasePart") then
                pos = d.Parent.Position
            end
            if pos then return d, pos end
        end
    end
    return nil, nil
end

local function getAllTargets()
    local t = {}
    local plots = Workspace:FindFirstChild("Plots")
    if not plots then return t end
    for _, plot in pairs(plots:GetChildren()) do
        if isMyPlot(plot) then continue end
        for _, desc in pairs(plot:GetDescendants()) do
            if desc:IsA("Model") and Database[desc.Name] then
                local root = desc:FindFirstChild("HumanoidRootPart") or desc.PrimaryPart
                if root then
                    local prompt, pos = findPromptInPodium(desc.Parent)
                    if not prompt and desc.Parent.Parent then
                        prompt, pos = findPromptInPodium(desc.Parent.Parent)
                    end
                    if prompt then
                        table.insert(t, {
                            prompt = prompt,
                            position = pos,
                            petName = desc.Name,
                            petValue = Database[desc.Name]
                        })
                    end
                end
            end
        end
    end
    return t
end

local function getPriorityTarget()
    local PS = getgenv().PrioritySystem
    if not PS or not PS.SelectedData then return nil end
    local d = PS.SelectedData
    if not d.plot or not d.slot then return nil end
    local plots = Workspace:FindFirstChild("Plots")
    if not plots then return nil end
    local plot = plots:FindFirstChild(d.plot)
    if not plot then return nil end
    local podiums = plot:FindFirstChild("AnimalPodiums")
    if not podiums then return nil end
    local podium = podiums:FindFirstChild(tostring(d.slot))
    if not podium then return nil end
    local prompt, pos = findPromptInPodium(podium)
    if prompt then
        return { prompt = prompt, position = pos, petName = d.name or "?", petValue = d.genValue or 0 }
    end
    return nil
end

local function getTarget()
    local hrp = getHRP()
    if not hrp then return nil end
    if AG.Mode == "Priority" then return getPriorityTarget() end
    local targets = getAllTargets()
    if #targets == 0 then return nil end
    if AG.Mode == "Nearest" then
        local best, min = nil, math.huge
        for _, x in ipairs(targets) do
            local dist = (hrp.Position - x.position).Magnitude
            if dist < min then min = dist best = x end
        end
        return best
    else
        local best, max = nil, -1
        for _, x in ipairs(targets) do
            if x.petValue > max then max = x.petValue best = x end
        end
        return best
    end
end

local function firePrompt(prompt)
    if not prompt or not prompt.Parent then return false end
    if fireproximityprompt then
        pcall(fireproximityprompt, prompt, 1)
        return true
    end
    local ok, conns = pcall(getconnections, prompt.Triggered)
    if ok and conns then
        for _, c in ipairs(conns) do
            if c.Function then pcall(c.Function) end
        end
        return true
    end
    local ok2, conns2 = pcall(getconnections, prompt.PromptButtonHoldBegan)
    if ok2 and conns2 then
        for _, c in ipairs(conns2) do
            if c.Function then pcall(c.Function) end
        end
        task.wait(prompt.HoldDuration or 1)
        local ok3, conns3 = pcall(getconnections, prompt.Triggered)
        if ok3 and conns3 then
            for _, c in ipairs(conns3) do
                if c.Function then pcall(c.Function) end
            end
        end
        return true
    end
    return false
end

local lastStealCount = 0
local function detectSteal()
    local bp = LocalPlayer:FindFirstChild("Backpack")
    if bp then
        local count = 0
        for _, c in pairs(bp:GetChildren()) do
            if c:IsA("Tool") then count = count + 1 end
        end
        local char = LocalPlayer.Character
        if char then
            for _, c in pairs(char:GetChildren()) do
                if c:IsA("Tool") then count = count + 1 end
            end
        end
        if count > lastStealCount then
            lastStealCount = count
            return true
        end
        lastStealCount = count
    end
    return false
end

pcall(function()
    local bp = LocalPlayer:FindFirstChild("Backpack")
    if bp then
        for _, c in pairs(bp:GetChildren()) do
            if c:IsA("Tool") then lastStealCount = lastStealCount + 1 end
        end
    end
    local char = LocalPlayer.Character
    if char then
        for _, c in pairs(char:GetChildren()) do
            if c:IsA("Tool") then lastStealCount = lastStealCount + 1 end
        end
    end
end)

local function isServerConfirmedNearPriority()
    local hrp = getHRP()
    if not hrp then return false end
    local prio = getPriorityTarget()
    if not prio or not prio.position then return false end
    local hrp2D = Vector2.new(hrp.Position.X, hrp.Position.Z)
    local prio2D = Vector2.new(prio.position.X, prio.position.Z)
    local dist = (hrp2D - prio2D).Magnitude
    if dist > NEAR_PRIORITY_DISTANCE then return false end
    local stealAttr = LocalPlayer:GetAttribute("Stealing")
    if stealAttr == true then return true end
    if prio.prompt and prio.prompt.Parent then
        local ok, conns = pcall(getconnections, prio.prompt.Triggered)
        if ok and conns and #conns > 0 then return true end
    end
    return false
end

local thread = coroutine.create(function()
    while AG.Running do
        local success, err = pcall(function()
            if not AG.Active then
                AG.IsStealing = false
                AG.CurrentPetName = ""
                AG.StealProgress = 0
                return
            end
            local target = getTarget()
            if not target or not target.prompt or not target.prompt.Parent then
                AG.IsStealing = false
                AG.CurrentPetName = ""
                return
            end
            AG.IsStealing = true
            AG.CurrentPetName = target.petName
            AG.StealProgress = 0
            firePrompt(target.prompt)
            local startTime = tick()
            local lastRefire = startTime
            while tick() - startTime < AG.StealDuration do
                AG.StealProgress = (tick() - startTime) / AG.StealDuration
                if AG.Mode == "Priority" and target.prompt and target.prompt.Parent then
                    if tick() - lastRefire >= 0.1 then
                        firePrompt(target.prompt)
                        lastRefire = tick()
                    end
                end
                if detectSteal() then
                    AG.StealCount = AG.StealCount + 1
                    AG.StealProgress = 1
                    break
                end
                if not target.prompt or not target.prompt.Parent then break end
                task.wait(1/60)
            end
            AG.StealProgress = 1
            task.wait(0.1)
            AG.IsStealing = false
            AG.CurrentPetName = ""
            AG.StealProgress = 0
        end)
        task.wait(0.1)
    end
end)
coroutine.resume(thread)

task.spawn(function()
    while AG.Running do
        task.wait(5)
        if coroutine.status(thread) == "dead" then
            thread = coroutine.create(function()
                while AG.Running do
                    pcall(function()
                        if AG.Active then
                            local target = getTarget()
                            if target and target.prompt and target.prompt.Parent then
                                AG.IsStealing = true
                                AG.CurrentPetName = target.petName
                                firePrompt(target.prompt)
                                local st = tick()
                                local lastRefire = st
                                while tick() - st < AG.StealDuration do
                                    AG.StealProgress = (tick() - st) / AG.StealDuration
                                    if AG.Mode == "Priority" and target.prompt and target.prompt.Parent then
                                        if tick() - lastRefire >= 0.1 then
                                            firePrompt(target.prompt)
                                            lastRefire = tick()
                                        end
                                    end
                                    if detectSteal() then
                                        AG.StealCount = AG.StealCount + 1
                                        break
                                    end
                                    if not target.prompt or not target.prompt.Parent then break end
                                    task.wait(1/60)
                                end
                                AG.IsStealing = false
                                AG.CurrentPetName = ""
                                AG.StealProgress = 0
                            end
                        end
                    end)
                    task.wait(0.15)
                end
            end)
            coroutine.resume(thread)
        end
    end
end)

