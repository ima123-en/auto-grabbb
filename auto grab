local function SaveSettings()
    pcall(function()
        if writefile then
            local activeToSave = AG.Active
            if AG.AutoTurnOnNearPriority and AG.Mode == "Priority" then
                activeToSave = false
            end
            local data = {
                Active = activeToSave,
                Mode = AG.Mode,
                AutoTurnOnNearPriority = AG.AutoTurnOnNearPriority
            }
            writefile(SAVE_KEY .. ".json", HttpService:JSONEncode(data))
        end
    end)
end

local function LoadSettings()
    pcall(function()
        if readfile and isfile and isfile(SAVE_KEY .. ".json") then
            local data = HttpService:JSONDecode(readfile(SAVE_KEY .. ".json"))
            if data.Active ~= nil then AG.Active = data.Active end
            if data.Mode then AG.Mode = data.Mode end
            if data.AutoTurnOnNearPriority ~= nil then AG.AutoTurnOnNearPriority = data.AutoTurnOnNearPriority end
        end
    end)
end

